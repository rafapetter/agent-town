{
  "name": "agent-town",
  "version": "0.1.0",
  "description": "Visualize your AI agents working in a pixel art office — framework-agnostic JavaScript library",
  "type": "module",
  "main": "dist/agent-town.umd.cjs",
  "module": "dist/agent-town.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/agent-town.js",
      "require": "./dist/agent-town.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "agents",
    "ai",
    "visualization",
    "pixel-art",
    "office",
    "canvas",
    "llm",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafapetter/agent-town"
  },
  "homepage": "https://github.com/rafapetter/agent-town#readme",
  "bugs": {
    "url": "https://github.com/rafapetter/agent-town/issues"
  },
  "author": "Rafael Petter",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
